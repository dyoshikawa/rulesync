{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "permissions": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-zA-Z0-9_]+$"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            {
              "pattern": "^[^()]*$"
            },
            {
              "pattern": "\\S"
            }
          ]
        },
        "additionalProperties": {
          "type": "string",
          "enum": ["allow", "ask", "deny"]
        }
      }
    }
  },
  "required": ["permissions"],
  "additionalProperties": {},
  "$id": "https://github.com/dyoshikawa/rulesync/releases/latest/download/permissions-schema.json",
  "title": "Rulesync Permissions Configuration",
  "description": "Permissions configuration file for Rulesync CLI tool"
}
