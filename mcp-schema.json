{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "mcpServers": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["stdio", "sse", "http"]
          },
          "command": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": "string"
          },
          "httpUrl": {
            "type": "string"
          },
          "env": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "disabled": {
            "type": "boolean"
          },
          "networkTimeout": {
            "type": "number"
          },
          "timeout": {
            "type": "number"
          },
          "trust": {
            "type": "boolean"
          },
          "cwd": {
            "type": "string"
          },
          "transport": {
            "type": "string",
            "enum": ["stdio", "sse", "http"]
          },
          "alwaysAllow": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kiroAutoApprove": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kiroAutoBlock": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "headers": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "enabledTools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disabledTools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "agentsmd",
                "agentsskills",
                "antigravity",
                "augmentcode",
                "augmentcode-legacy",
                "claudecode",
                "claudecode-legacy",
                "cline",
                "codexcli",
                "copilot",
                "cursor",
                "factorydroid",
                "geminicli",
                "goose",
                "junie",
                "kilo",
                "kiro",
                "opencode",
                "qwencode",
                "replit",
                "roo",
                "warp",
                "windsurf",
                "zed",
                "*"
              ]
            }
          },
          "description": {
            "type": "string"
          },
          "exposed": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["mcpServers"],
  "additionalProperties": false,
  "$id": "https://raw.githubusercontent.com/dyoshikawa/rulesync/refs/heads/main/mcp-schema.json",
  "title": "Rulesync MCP Configuration",
  "description": "MCP server configuration file for Rulesync CLI tool"
}
